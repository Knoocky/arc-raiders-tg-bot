# Telegram bot token
BOT_TOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arc_raiders_bot

# Logging
LOG_LEVEL=INFO

# Provider
PROVIDER_BASE_URL=https://metaforge.app/api/arc-raiders
PROVIDER_SCHEDULE_PATH=/events-schedule
PROVIDER_EVENTS_CATALOG_PATH=/events
PROVIDER_TIMEOUT_SECONDS=10

# Scheduler
CATALOGS_REFRESH_MINUTES=720
SCHEDULE_REFRESH_MINUTES=30
NOTIFICATION_POLL_SECONDS=60
